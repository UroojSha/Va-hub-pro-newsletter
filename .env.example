# Copy this file to ".env" for local development, and set the same variables in
# Vercel (Project Settings -> Environment Variables) for production.

# --- Claude API ---
# Your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model used to write the emails. Change anytime without code edits.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- GoHighLevel ---
# The GHL inbound webhook URL the generated email is POSTed to.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-webhook-id
# Your GHL location ID (added to the payload as "locationId" when set; optional).
GHL_LOCATION_ID=your_location_id

# --- Security ---
# Secret that protects the scheduled /api/cron endpoint. Use a long random
# string. Vercel automatically sends this as a Bearer token to your cron path.
CRON_SECRET=change_me_to_a_long_random_string
# Password for the web page (Lawrence uses this to log in).
PAGE_PASSWORD=choose_a_password

# --- Local server only (ignored on Vercel) ---
# Port for local "npm start".
PORT=3000
# In-process scheduler (only runs when self-hosting, not on Vercel).
# Default is Monday 9am US Eastern.
CRON_SCHEDULE=0 9 * * 1
CRON_TZ=America/New_York
